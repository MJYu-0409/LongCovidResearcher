 initials="P">Priyanka</given-names></name><xref rid="aff1" ref-type="aff">1</xref></contrib><contrib contrib-type="author"><name name-style="western"><surname>Dominic</surname><given-names initials="M">Melvin</given-names></name><xref rid="aff2" ref-type="aff">2</xref></contrib><contrib contrib-type="author"><name name-style="western"><surname>Balakrishnan</surname><given-names initials="S">Sudhiersharan</given-names></name><xref rid="aff2" ref-type="aff">2</xref></contrib><contrib contrib-type="author"><name name-style="western"><surname>Sreelakshmi</surname><given-names initials="VK">V. K.</given-names></name><xref rid="aff2" ref-type="aff">2</xref></contrib><contrib contrib-type="author"><name name-style="western"><surname>Haneendhar</surname><given-names initials="R">R.</given-names></name><xref rid="aff2" ref-type="aff">2</xref></contrib><contrib contrib-type="author"><name name-style="western"><surname>Gopan</surname><given-names initials="SJ">S. Jithin</given-names></name><xref rid="aff2" ref-type="aff">2</xref></contrib><contrib contrib-type="author"><name name-style="western"><surname>Rathnasami</surname><given-names initials="P">Pragnesh</given-names></name><xref rid="aff2" ref-type="aff">2</xref></contrib><contrib contrib-type="author"><name name-style="western"><surname>Moturi</surname><given-names initials="SV">Sai Vineeth</given-names></name><xref rid="aff2" ref-type="aff">2</xref><xref rid="cor1" ref-type="corresp"/></contrib></contrib-group><aff id="aff1"><label>1</label>Department of General Medicine, Pondicherry Institute of Medical Sciences, Pondicherry University, Pondicherry, Tamil Nadu, India</aff><aff id="aff2"><label>2</label>Department of Emergency Medicine, Vinayaka Missions Kirupananda Variyar Medical College and Hospital, Vinayaka Mission Research Foundation, Salem, Tamil Nadu, India</aff><author-notes><corresp id="cor1">
